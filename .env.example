# Database (any strong string for local dev)
DB_PASSWORD=changeme_local_dev

# Auth.js v5 (generate via: npx auth secret)
AUTH_SECRET=

# GitHub OAuth — register app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth — register at https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Microsoft Entra ID — register at https://entra.microsoft.com (App registrations)
# Callback URL: http://localhost:3000/api/auth/callback/microsoft-entra-id
# Issuer: https://login.microsoftonline.com/common/v2.0  (use 'common' for multi-tenant)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/common/v2.0

# URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
